@inproceedings{GridGAS2018,
  title = {{{GridGAS}}: {{An I}}/{{O-Efficient Heterogeneous FPGA}}+{{CPU Computing Platform}} for {{Very Large-Scale Graph Analytics}}},
  shorttitle = {{{GridGAS}}},
  booktitle = {2018 {{International Conference}} on {{Field-Programmable Technology}} ({{FPT}})},
  author = {Zou, Yu and Lin, Mingjie},
  year = 2018,
  month = dec,
  pages = {246--249},
  doi = {10.1109/FPT.2018.00045},
  urldate = {2025-11-16},
  abstract = {In this paper, we develop a highly scalable approach to constructing an efficient heterogeneous graph processing engine in order to handle extremely large graph size beyond its on-board memory capacity. Our FPGA-based computing engine not only surpasses cutting-edge GPU-based engines in terms of computing performance and energy efficiency, but also proves to be highly versatile and thus can be applied to many types of low-latency and high-throughput graph analytic tasks central to the next-generation graph-based machine learning. We analyze in detail the difference between GPU's and FPGA's architectures and provide several fundamental reasons why, for irregular computations, FPGA may surpass GPU in computing latency and energy efficiency, and discuss some ``golden rules'' for designing an efficient FPGA+CPU heterogeneous platform and GPU's inefficiency when handling extremely large-scale graph datasets. To validate our approach, we implement our FPGA-based GridGAS computing engine with a KC705 Xilinx FPGA board and a baseline implementation using a Quadro K420 GPU following the same approach, and test with large-scale graph datasets. Using PCIe 2.0 \texttimes 8 only, our architecture achieves up to 170.4 MTEPS and 14.8 times speedup over the GPU baseline for datasets exceeding 1.4 GB in size.},
  keywords = {Clocks,Computer architecture,Engines,Field programmable gate arrays,Graph processing,Graphics processing units,Hardware,Heterogeneous system,Instruction sets}
}

@article{gulatiFPGAbasedHardwareAcceleration2009,
  title = {{{FPGA-based}} Hardware Acceleration for {{Boolean}} Satisfiability},
  author = {Gulati, Kanupriya and Paul, Suganth and Khatri, Sunil P. and Patil, Srinivas and Jas, Abhijit},
  year = 2009,
  month = mar,
  journal = {ACM Transactions on Design Automation of Electronic Systems},
  volume = {14},
  number = {2},
  pages = {1--11},
  issn = {1084-4309, 1557-7309},
  doi = {10.1145/1497561.1497576},
  urldate = {2025-11-29},
  abstract = {We present an FPGA-based hardware solution to the Boolean satisfiability (SAT) problem, with the main goals of scalability and speedup. In our approach the traversal of the implication graph as well as conflict clause generation are performed in hardware, in parallel. The experimental results and their analysis, along with the performance models are discussed. We show that an order of magnitude improvement in runtime can be obtained over MiniSAT (the best-in-class software based approach) by using a Virtex-4 (XC4VFX140) FPGA device. The resulting system can handle instances with as many as 10K variables and 280K clauses.},
  langid = {english}
}

@misc{hamiltonRepresentationLearningGraphs2018a,
  title = {Representation {{Learning}} on {{Graphs}}: {{Methods}} and {{Applications}}},
  shorttitle = {Representation {{Learning}} on {{Graphs}}},
  author = {Hamilton, William L. and Ying, Rex and Leskovec, Jure},
  year = 2018,
  month = apr,
  number = {arXiv:1709.05584},
  eprint = {1709.05584},
  primaryclass = {cs},
  publisher = {arXiv},
  urldate = {2023-08-13},
  abstract = {Machine learning on graphs is an important and ubiquitous task with applications ranging from drug design to friendship recommendation in social networks. The primary challenge in this domain is finding a way to represent, or encode, graph structure so that it can be easily exploited by machine learning models. Traditionally, machine learning approaches relied on user-defined heuristics to extract features encoding structural information about a graph (e.g., degree statistics or kernel functions). However, recent years have seen a surge in approaches that automatically learn to encode graph structure into low-dimensional embeddings, using techniques based on deep learning and nonlinear dimensionality reduction. Here we provide a conceptual review of key advancements in this area of representation learning on graphs, including matrix factorization-based methods, random-walk based algorithms, and graph neural networks. We review methods to embed individual nodes as well as approaches to embed entire (sub)graphs. In doing so, we develop a unified framework to describe these recent approaches, and we highlight a number of important applications and directions for future work.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning,Computer Science - Social and Information Networks},
  file = {/home/alex/snap/zotero-snap/common/Zotero/storage/7JQQ3AET/Hamilton и др. - 2018 - Representation Learning on Graphs Methods and App.pdf;/home/alex/snap/zotero-snap/common/Zotero/storage/EM67BV7H/1709.html}
}

