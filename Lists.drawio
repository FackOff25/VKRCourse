        <mxCell id="pAsqDZSeMrLAsJyq7KDE-0" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="Выделяют часто используемые группы элементов и перемещать их вместе." vertex="1">
          <mxGeometry height="100" width="1510" x="1710" y="210" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-1" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="Taper строит матрицу вероятностей для каждого шарда для расчёта &quot;экстравертных&quot; вершин и выделения их &quot;семей&quot;, которые используются в одних и тех же запросах." vertex="1">
          <mxGeometry height="100" width="1510" x="1710" y="420" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-2" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="&lt;div&gt;Перераспределение имеет схожую с алгоритмом Кернигана-Лина итеративную структуру, но с перемещением целых групп (семей) вершин.&lt;/div&gt;" vertex="1">
          <mxGeometry height="730" width="450" x="1710" y="670" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-3" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="&lt;div&gt;Продолжение идей Taper с поиском часто используемых групп, в данном алгоритме называемых&quot;мотивами&quot;.&lt;/div&gt;&lt;div&gt;Для их поиска строится древовидная&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="419.98" width="500" x="1700" y="1520.02" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-4" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="&lt;div&gt;структура&amp;nbsp;TPSTry++ на основе запросов.&amp;nbsp;TPSTry++ состоит из уникальных подграфов и в зависимости от их использования в&lt;/div&gt;" vertex="1">
          <mxGeometry height="140.87" width="1560" x="1700" y="1959.13" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-5" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="подграфы с высоким вхождением в запросы, называются мотивами и их стараются разместить вместе." vertex="1">
          <mxGeometry height="200.74" width="824.37" x="1705.63" y="2089.26" as="geometry" />
        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-6" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="Каждый элемент рассматривается в отрыве от остальных." vertex="1">
