        <mxCell id="XU5GAt2UBmYbscp_z5CM-96" parent="XU5GAt2UBmYbscp_z5CM-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=GOST Type B;strokeWidth=2;fontSize=18;" value="&lt;font&gt;&lt;i&gt;Выпускная квалификационная работа магистра&lt;/i&gt;&lt;/font&gt;" vertex="1">
