        </mxCell>
        <mxCell id="pAsqDZSeMrLAsJyq7KDE-7" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;fontStyle=1" value="Schism" vertex="1">
