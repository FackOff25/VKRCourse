        <mxCell id="aqHPKL5Qll4LZYUbcDp5-5" parent="9r99qVaiX-5ctrWOaMb8-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="450.82" width="1050" x="2200" y="1500" as="geometry" />
