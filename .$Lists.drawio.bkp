        <mxCell id="_hu7UDtJUXKWaTYcDsXp-386" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=ГОСТ тип А;fontSize=52;" value="&lt;span style=&quot;color: rgb(0, 0, 0);&quot; class=&quot;docData;DOCY;v5;2277;&quot;&gt;Целью работы является создание программного модуля, сокращающего количество &lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;межшардовых&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt; переходов во время запросов в распределённые &lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;графовые&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt; БД для уменьш&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;е&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;ния времени запроса.&lt;/span&gt;" vertex="1">
