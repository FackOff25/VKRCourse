        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam shadowing false\nskinparam classFontSize 11\nskinparam monochrome true\nskinparam dpi 300\nskinparam nodesep 60\nskinparam ranksep 80\n\n&#39; ====================== Интерфейсы ======================\ninterface IStorage&lt;KeyType&gt; {\n  +get_id() : int\n  +connect_to_bus(IBus) : void\n  +add_node(Node) : optional&lt;set&lt;Edge&gt;&gt;\n  +add_node_and_announce(Node) : optional&lt;set&lt;Edge&gt;&gt;\n  +remove_node(Key) : bool\n  +remove_node_and_announce(Key) : bool\n  +get_node(Key) : Node*\n  +has_node(Key) : bool\n  +get_all_nodes() : const map&lt;Key, Node&gt;\n  +size() : size_t\n  +internal_edges_size() : size_t\n  +get_streaming_euristics_change(Node, long) : float\n  +get_nodes_with_neighbors_in_storage(int) : set&lt;Node&gt;\n  +get_all_edges_to_storage(int) : set&lt;Edge&gt;\n}\n\ninterface IBus&lt;KeyType&gt; {\n  +request_node(Key) : Node\n  +send_add_node(Node) : int\n  +send_add_node(Node, int) : bool\n  +send_remove_node(Key) : bool\n  +send_remove_node(Key, int) : bool\n  +ask_who_has(int, Key) : int\n  +announce_add(Key, int, set&lt;Edge&gt;) : void\n  +announce_remove(Key, int) : void\n  +ask_neigbours_to_storage(int, int) : set&lt;Node&gt;\n  +ask_edges_to_storage(int, int) : set&lt;Edge&gt;\n}\n\n&#39; ====================== Основные классы ======================\nclass NodeKey&lt;KeyType&gt; {\n  +key_value : KeyType\n}\n\nclass Edge&lt;KeyType&gt; {\n  -weight : float\n  -directional : bool\n  -from : NodeKey\n  -to : NodeKey\n  -parameters : map&lt;string, Parameter&gt;\n  +get_weight() : float\n  +get_from() : NodeKey\n  +get_to() : NodeKey\n  +get_other(NodeKey) : NodeKey\n}\n\nclass Node&lt;KeyType&gt; {\n  -key : NodeKey\n  +parameters : map&lt;string, Parameter&gt;\n  +edges : map&lt;NodeKey, Edge&gt;\n  +add_edge(Edge) : void\n  +remove_edge_to(NodeKey) : bool\n}\n\nclass Storage&lt;KeyType&gt; {\n  -storage_id : int\n  -nodes : map&lt;Key, Node&gt;\n  -external_edges : map&lt;int, map&lt;Key, map&lt;Key, Edge&gt;&gt;&gt;\n  -internal_edges : size_t\n  -bus : IBus*\n  +add_node(Node) : optional&lt;set&lt;Edge&gt;&gt;\n  +remove_node(Key) : bool\n  +get_nodes_with_neighbors_in_storage(int) : set&lt;Node&gt;\n  +get_all_edges_to_storage(int) : set&lt;Edge&gt;\n  +internal_edges_size() : size_t\n}\n\nclass SimpleStorage&lt;KeyType&gt; {\n  &lt;&lt;Simple version&gt;&gt;\n}\n\nclass FennelStorage&lt;KeyType&gt; {\n  -params : FennelParameters\n  -number_of_nodes : int\n  +get_streaming_euristics_change(Node, long) : float\n}\n\nclass SimpleBus&lt;KeyType&gt; {\n  -storages : map&lt;int, IStorage*&gt;\n  -total_edges : long\n  +connect_storage(IStorage) : int\n  +send_add_node(Node) : int\n}\n\nclass FennelParameters {\n  +storage_number : int\n  +balancing_number : float\n}\n\nclass Parameter {\n  -data : vector&lt;byte&gt;\n}\n\n&#39; ====================== Отношения ======================\nIStorage &lt;|.. Storage\nStorage &lt;|.. SimpleStorage\nStorage &lt;|.. FennelStorage\nIBus &lt;|.. SimpleBus\n\nStorage \&quot;1\&quot; o--&gt; \&quot;*\&quot; Node : nodes\nStorage o--&gt; Edge : external_edges\nStorage --&gt; IBus : bus\n\nSimpleBus \&quot;1\&quot; o--&gt; \&quot;*\&quot; IStorage : storages\n\nNode \&quot;1\&quot; --&gt; \&quot;1\&quot; NodeKey : key\nNode \&quot;1\&quot; o--&gt; \&quot;*\&quot; Edge : edges\nEdge --&gt; NodeKey : from, to\n\nFennelStorage --&gt; FennelParameters\nEdge \&quot;1\&quot; o--&gt; \&quot;*\&quot; Parameter : parameters\nNode \&quot;1\&quot; o--&gt; \&quot;*\&quot; Parameter : parameters\n\nnote right of NodeKey\n  KeyType — шаблонный параметр\nend note\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="xJWPg4RDSbyUS1FhfHN3-142">
          <mxCell parent="fUKXwNhwHcpENq5G5GuE-1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1864.49" width="3132.83" x="110" y="169.44" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
