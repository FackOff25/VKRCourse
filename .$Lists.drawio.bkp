          <mxGeometry height="54.8" width="272.87" x="67.10049999999967" y="30.329999999999927" as="geometry" />
        </mxCell>
        <mxCell id="XU5GAt2UBmYbscp_z5CM-104" parent="XU5GAt2UBmYbscp_z5CM-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="Каждая вершина вносит свой вклад в общее плохое распределение графа в данный момент. В таком случае можно посчитать этот вклад, &quot;внешнюю стоимость&quot; и переместить самые вредные вершины в места, где они будут вредить меньше всего.&lt;div&gt;В теории можно считать потенциальную внешнюю стоимость вершины для каждого хранилища и перемещать её туда, но на практике это может повредить балансировке нагрузки, а также блокирует всё хранилище на время уточнения и имеет огромную вычислительную стоимость, в то время как попарное уточнение позволяет обменивать вершины, не влияя на баланс нагрузки, оставляет разблокированной остальную систему и имеет модификацию, которая сильно легче в вычислительном плане.&lt;/div&gt;" vertex="1">
          <mxGeometry height="870" width="1360" x="1260" y="200" as="geometry" />
        </mxCell>
        <mxCell id="XU5GAt2UBmYbscp_z5CM-390" parent="XU5GAt2UBmYbscp_z5CM-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=60;fontFamily=ГОСТ тип А;fontStyle=1" value="Формула внешней стоимости" vertex="1">
          <mxGeometry height="60" width="860" x="100.99000000000004" y="110" as="geometry" />
        </mxCell>
