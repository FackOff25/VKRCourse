        <mxCell id="_hu7UDtJUXKWaTYcDsXp-494" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=ГОСТ тип А;fontSize=52;align=left;" value="&lt;p class=&quot;ds-markdown-paragraph&quot;&gt;Актуальность работы&lt;strong&gt;&amp;nbsp;&lt;/strong&gt;обусловлена необходимостью сокращения межшардовых переходов в распределённых графовых БД для уменьшения времени запросов. Существующие методы (METIS, хеширование) не учитывают реальную нагрузку запросов и работают только в статическом режиме. Разработка модуля, сочетающего структурные и потоковые методы с учётом данных о запросах, позволяет адаптивно улучшать распределение вершин и снижать задержки, что востребовано в высоконагруженных графовых системах.&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="2020" x="480" y="3020" as="geometry" />
        </mxCell>
        <mxCell id="_hu7UDtJUXKWaTYcDsXp-495" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=ГОСТ тип А;fontSize=60;fontStyle=1" value="Актуальность" vertex="1">
          <mxGeometry height="90" width="360" x="482.34000000000003" y="2965" as="geometry" />
        </mxCell>
        <mxCell id="_hu7UDtJUXKWaTYcDsXp-602" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=ГОСТ тип А;fontSize=52;" value="Даже хорошее распределение с малым кол-ом ребёр между шардами не гарантирует малое количество межшардовых переходов, так как оно также зависит от специфики использования графа в данной сфере." vertex="1">
          <mxGeometry height="120" width="1020" x="490" y="4010" as="geometry" />
        </mxCell>
