        <mxCell id="gb_JFcazdJP61mvR4zSZ-400" parent="9r99qVaiX-5ctrWOaMb8-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=52;fontFamily=ГОСТ тип А;" value="Модификация Schism. Упрощает граф нагрузки, убирая, а точнее не добавляя в него малозначимые рёбра, выставляя порог для добавления такого ребра. Также вместо рассмотреня каждого запроса в отдельности запросы по какому-либо признаку, например, типу доступа, агрегируются в кластеры и значимость выставляется исходя из этих кластеров." vertex="1">
          <mxGeometry height="100" width="1510" x="110" y="980" as="geometry" />
        </mxCell>
        <mxCell id="gb_JFcazdJP61mvR4zSZ-403" edge="1" parent="9r99qVaiX-5ctrWOaMb8-1" style="endArrow=classic;html=1;rounded=0;strokeWidth=3;" value="">
